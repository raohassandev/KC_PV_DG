# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.

/.esphome/
# ESPHome compile copies (see scripts/export_pv_dg_firmware.sh)
/Modular_Yaml/firmware-out/*.bin
/Modular_Yaml/firmware-out/*.elf
/Modular_Yaml/firmware-out/*.factory.bin
/Modular_Yaml/firmware-out/*.ota.bin
/Modular_Yaml/firmware-out/bootloader.bin
/Modular_Yaml/firmware-out/partitions.bin
/Modular_Yaml/firmware-out/ota_data_initial.bin
/secrets.yaml
/Modular_Yaml/secrets.yaml

# Local-only copy of dev / deployment credentials (see CREDENTIALS.local.example)
/Export/secrets.yaml
/CREDENTIALS.local.md

# Dynamic Zero Export API simulator persisted state (local dev)
/dynamic_zero_export/state/
/PWA/state/

# Node (dynamic_zero_export has no package-local .gitignore)
/dynamic_zero_export/node_modules/

/gateway/node_modules/
/gateway/data/

# Playwright gateway E2E (ephemeral auth + sites)
/PWA/.e2e-gateway-config/

# PDFs (ignore all PDF files)
*.pdf

# Local screenshots accidentally dropped in repo root
/Screenshot*.png

# PDF/XLSX parsing temporary outputs (generated)
/docs/_extracted/

