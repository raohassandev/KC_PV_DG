{
  "name": "pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n sim,vite -c cyan,magenta \"npm run sim --prefix ../dynamic_zero_export\" \"vite\"",
    "dev:e2e": "concurrently -k -n sim,vite -c cyan,magenta \"npm run sim --prefix ../dynamic_zero_export\" \"vite --port 5183 --strictPort\"",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "test": "node --test --import tsx src/features/dynamic-zero-export/tests/*.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:gateway": "E2E_WITH_GATEWAY=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run build && npm run test:e2e",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
