# VPS deployment env (Docker Compose)
#
# Copy to `.env` and fill values. Keep `.env` private.

# ---- Gateway public URL / CORS ----
# Recommended: set to your final PWA URL (comma-separated allowed).
# Example: https://pv-dg.example.com
CORS_ORIGIN=

# Gate LAN-only endpoints on the VPS gateway (implemented in code in security-hardening step).
# 1 = public internet-facing gateway (LAN scan/probe disabled)
# 0 = trusted LAN/edge gateway (LAN scan/probe enabled)
KC_PVDG_PUBLIC_MODE=1

# ---- MQTT (optional) ----
MQTT_URL=
MQTT_DISCOVERY_TOPIC=automatrix/discovery/+/+

# ---- Initial passwords (first boot only) ----
# Set strong passwords before first deploy, then remove from `.env` after initialization.
INITIAL_USER_PASSWORD=
INITIAL_INSTALLER_PASSWORD=
INITIAL_SUPPORT_PASSWORD=
INITIAL_MANUFACTURER_PASSWORD=

